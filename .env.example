# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Required to create Stripe Checkout Sessions (Backend)
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_WEBHOOK_SECRET: Required to verify events received from Stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# SignNow Integration Variables
SIGNNOW_API_KEY="your-static-bearer-token"
SIGNNOW_TEMPLATE_ID="your-template-id"

# Automatic SignNow Token Generation (optional, recommended over static API key)
SIGNNOW_BASIC_TOKEN="your-base64-app-secret-token"
SIGNNOW_USERNAME="your-signnow-email"
SIGNNOW_PASSWORD="your-signnow-password"
